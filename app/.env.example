# Database — SQLite file path (relative to app/ directory)
DATABASE_URL="file:./perspectives.db"

# Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-random-secret"

# Reference libraries — absolute path to directory containing detection_act_library.yaml and thinking_behavior_library.yaml
REFERENCE_LIBRARIES_PATH="/path/to/configs/reference"

# Scenario registry — absolute path to directory containing scenario subdirectories (each with script.yaml, evaluation.yaml, etc.)
REGISTRY_PATH="/path/to/registry"
